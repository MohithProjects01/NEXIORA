generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Ownership {
  GOVERNMENT
  PRIVATE
}

enum Exam {
  JEE_MAIN
  KCET
  COMEDK
}

enum Category {
  GENERAL
  OBC
  SC
  ST
  EWS
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviews       Review[]
  savedColleges SavedCollege[]
  comparisons   Comparison[]
  predictions   PredictionHistory[]

  @@index([email])
}

model College {
  id                  String    @id @default(cuid())
  slug                String    @unique
  name                String
  description         String    @db.Text
  location            String
  state               String
  ownership           Ownership
  fees                Float
  rating              Float     @default(0)
  placementPercentage Float     @default(0)
  averagePackage      Float     @default(0)
  highestPackage      Float     @default(0)
  website             String?
  topRecruiters       String[]
  establishedYear     Int
  image               String?
  featured            Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  courses       Course[]
  reviews       Review[]
  savedBy       SavedCollege[]

  @@index([slug])
  @@index([name])
  @@index([state])
  @@index([location])
  @@index([ownership])
  @@index([rating])
  @@index([fees])
  @@index([placementPercentage])
  @@index([highestPackage])
  @@index([featured])
  @@index([state, ownership])
}

model Course {
  id        String  @id @default(cuid())
  collegeId String
  name      String
  duration  String
  fees      Float

  college College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  collegeId String
  rating    Int
  comment   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  college College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([userId, collegeId])
  @@index([userId])
  @@index([collegeId])
}

model SavedCollege {
  id        String   @id @default(cuid())
  userId    String
  collegeId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  college College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([userId, collegeId])
  @@index([userId])
  @@index([collegeId])
}

model Comparison {
  id         String   @id @default(cuid())
  userId     String
  collegeIds String[]
  title      String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PredictionHistory {
  id        String   @id @default(cuid())
  userId    String
  exam      Exam
  rank      Int
  category  Category
  state     String
  results   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
